# ═══════════════════════════════════════════════════════════════
# TVC OPERATIONS - ENVIRONMENT VARIABLES
# Issue #82 — Complete environment configuration
# ═══════════════════════════════════════════════════════════════
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env.local: cp .env.example .env.local
# 2. Fill in the values below
# 3. Restart the dev server: npm run dev
#
# For Vercel deployment:
# 1. Go to Project Settings > Environment Variables
# 2. Add each variable with its value
# 3. Redeploy
#
# DIAGNOSTIC PAGE:
# Visit /error-config to see which variables are configured
#
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# SUPABASE (REQUIRED)
# Get from: Supabase Dashboard > Project Settings > API
# ─────────────────────────────────────────────────────────────────

# Project URL - The URL of your Supabase project
# Format: https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anonymous/Public Key - Safe to expose in browser
# Used for: Client-side database access (respects RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# Service Role Key - KEEP SECRET, never expose to client
# Used for: Server-side operations that bypass RLS
# WARNING: This key has full database access
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# ─────────────────────────────────────────────────────────────────
# ANTHROPIC CLAUDE API (Required for AI features)
# Get from: console.anthropic.com
# ─────────────────────────────────────────────────────────────────

# Claude API Key for staff bot and AI features
# Format: sk-ant-api03-xxxx
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ─────────────────────────────────────────────────────────────────
# TWILIO WHATSAPP (Required for WhatsApp messaging)
# Get from: twilio.com/console
# ─────────────────────────────────────────────────────────────────

# Twilio Account SID - Found on main dashboard
# Format: ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Auth Token - Found on main dashboard (click to reveal)
TWILIO_AUTH_TOKEN=your-auth-token-here

# WhatsApp Sender Number - Your Twilio WhatsApp number
# Format: whatsapp:+1234567890
# For sandbox: whatsapp:+14155238886
# For business: Your verified number
TWILIO_WHATSAPP_FROM=whatsapp:+573160551387

# ─────────────────────────────────────────────────────────────────
# TVC STAFF NOTIFICATIONS
# Staff phone number for escalation alerts
# ─────────────────────────────────────────────────────────────────

# WhatsApp number to receive escalation alerts
# Format: whatsapp:+1234567890
TVC_STAFF_WHATSAPP=whatsapp:+573160551387

# ─────────────────────────────────────────────────────────────────
# WEATHER API (Required for weather widget)
# Get from: openweathermap.org/api_keys
# ─────────────────────────────────────────────────────────────────

# OpenWeatherMap API Key
OPENWEATHER_API_KEY=your-openweather-api-key

# ─────────────────────────────────────────────────────────────────
# GOOGLE REVIEW (Required for review request feature)
# Get from: Google Business Profile
# ─────────────────────────────────────────────────────────────────

# Google Review Link for TVC
# Format: https://g.page/r/your-review-link
GOOGLE_REVIEW_LINK=https://g.page/r/your-google-review-link

# ─────────────────────────────────────────────────────────────────
# APP CONFIGURATION
# ─────────────────────────────────────────────────────────────────

# Public URL of the app (for absolute URLs in emails, etc.)
NEXT_PUBLIC_APP_URL=https://villa-tvc.vercel.app

# Environment (development, production, test)
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────────

# Cron Job Secret - Protects cron endpoints from unauthorized access
# Generate with: openssl rand -hex 32
# Used in: /api/cron/* routes via Authorization header
CRON_SECRET=your-32-character-secret-key-here-generate-with-openssl

# ═══════════════════════════════════════════════════════════════
# FEATURE STATUS SUMMARY
# ═══════════════════════════════════════════════════════════════
#
# Core App (NEXT_PUBLIC_SUPABASE_*):
#   - Database access
#   - User authentication
#   - All CRUD operations
#
# AI Features (ANTHROPIC_API_KEY):
#   - Staff bot responses
#   - Guest conversation AI
#   - Smart suggestions
#
# WhatsApp (TWILIO_*):
#   - Guest messaging
#   - Staff notifications
#   - Escalation alerts
#
# Weather (OPENWEATHER_API_KEY):
#   - Weather widget on dashboard
#   - Weather-based recommendations
#
# Reviews (GOOGLE_REVIEW_LINK):
#   - Post-checkout review requests
#   - Review analytics
#
# Cron Jobs (CRON_SECRET):
#   - Automated status transitions
#   - Scheduled notifications
#   - Periodic cleanup
#
# ═══════════════════════════════════════════════════════════════
